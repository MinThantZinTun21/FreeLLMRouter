---
import Layout from '../../layouts/base.astro';
import { ModelsPage } from '../../components/ModelsPage';
import DataAttributionFooter from '../../components/DataAttributionFooter.astro';
---

<Layout
  title="Free Model Availability - Free LLM Router"
  description="Track availability history for free OpenRouter models. Compare daily uptime trends and see which free models remain available over time."
  url="/models/availability"
>
  <div class="container mx-auto max-w-5xl px-4 py-8">
    <ModelsPage currentView="availability" client:load />

    <DataAttributionFooter class="mt-16 pt-8" />
  </div>
</Layout>
