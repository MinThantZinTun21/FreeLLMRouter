---
import Layout from '../layouts/base.astro';
import { ModelsPage } from '../components/ModelsPage';
import DataAttributionFooter from '../components/DataAttributionFooter.astro';
---

<Layout
  title="Free Model Health - Free LLM Router"
  description="Browse health data for free OpenRouter models. Compare reliability, error rates, and community reports to find working free AI models."
  url="/models"
>
  <div class="container mx-auto max-w-5xl px-4 py-8">
    <ModelsPage client:load />

    <DataAttributionFooter class="mt-16 pt-8" />
  </div>
</Layout>
